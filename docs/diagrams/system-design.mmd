%% JTracer v2 — System Architecture (updated June 2026)
%% See docs/SYSTEM_DESIGN.md for narrative and implementation notes.
%% Collectors run on the host OS; API/UI may optionally run in Docker.

flowchart TB
    subgraph futureK8s["Future Kubernetes Layer (planned)"]
        direction TB
        k8sIngress["Ingress / Gateway"]
        k8sBackend["Backend API Deployment"]
        k8sFrontend["Frontend Deployment"]
        k8sDB["PostgreSQL PVC"]
        k8sIngress --> k8sFrontend
        k8sIngress --> k8sBackend
        k8sBackend --> k8sDB
    end

    subgraph dockerLayer["Docker Layer (optional — API only)"]
        direction TB
        dockerBackend["Spring Boot API Container\nprofile: docker"]
        dockerVolume["./data bind mount\njtracer-live.db"]
        dockerKB["knowledge-base/ (ro)"]
        dockerBackend --> dockerVolume
        dockerBackend --> dockerKB
    end

    subgraph macHost["macOS Host (primary target)"]
        direction TB

        subgraph hostCollectors["Host-Native Collectors ✅"]
            direction LR
            processCollector["Process Collector\nps · df · pmset"]
            networkCollector["Network Collector\nlsof · reverse DNS"]
            lanScanner["LAN Scanner\narp · ping"]
        end

        subgraph knowledgeBase["Device Identity Knowledge Base ✅"]
            direction TB
            ouiDb["oui-vendors.json"]
            deviceRules["device-rules.json"]
            mdnsServices["mdns-services.json"]
            userLabels["user_device_labels"]
        end

        identityResolver["Rule-Based Identity Resolver ✅"]
        lanScanner --> identityResolver
        ouiDb --> identityResolver
        deviceRules --> identityResolver
        mdnsServices --> identityResolver
        userLabels --> identityResolver
    end

    subgraph appStack["Application Stack"]
        direction TB
        coordinator["Collector Coordinator\nscheduled polls"]
        restApi["REST API /api/v1 🚧\nGET /system/health ✅"]
        cors["CORS → localhost:5173"]
        sqlite["SQLite jtracer-live.db\nFlyway V1–V4"]
        reactUi["React Dashboard\n(planned Phase 8)"]
        persistenceProviders["PersistenceProvider\nLocalSQLite (MVP)"]
    end

    processCollector --> coordinator
    networkCollector --> coordinator
    lanScanner --> coordinator
    identityResolver --> coordinator

    coordinator -->|"persist snapshots"| sqlite
    sqlite -->|"read models"| restApi
    cors --> restApi
    restApi -->|"JSON envelope"| reactUi
    persistenceProviders -.-> sqlite

    dockerBackend -.->|"optional packaging"| restApi

    futureK8s -.->|"future productization"| dockerLayer

    classDef host fill:#e8f4ea,stroke:#2d6a4f,stroke-width:2px
    classDef docker fill:#dbeafe,stroke:#1d4ed8,stroke-width:2px
    classDef future fill:#f3e8ff,stroke:#7c3aed,stroke-width:2px,stroke-dasharray: 5 5
    classDef app fill:#fef3c7,stroke:#d97706,stroke-width:2px
    classDef done fill:#d1fae5,stroke:#059669,stroke-width:2px

    class processCollector,networkCollector,lanScanner,identityResolver,ouiDb,deviceRules,mdnsServices,userLabels done
    class dockerBackend,dockerVolume,dockerKB docker
    class k8sIngress,k8sBackend,k8sFrontend,k8sDB future
    class coordinator,restApi,cors,sqlite,reactUi,persistenceProviders app
